# URL of the service worker (generated by serwist at build time)
NEXT_PUBLIC_SW_URL=/sw.js

NEXT_PUBLIC_COUNTERAPI_KEY=your_api_key_here

# Discord webhook for issue reports
NEXT_PUBLIC_DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Groq — AI word explanation (client-side, key is intentionally public for now)
# Get your key: https://console.groq.com/keys
# Available models: https://console.groq.com/docs/models
NEXT_PUBLIC_GROQ_API_KEY=
NEXT_PUBLIC_GROQ_MODEL=llama-3.1-8b-instant
NEXT_PUBLIC_AI_DAILY_LIMIT=30